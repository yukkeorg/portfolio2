---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About" description="About Ohshima Yusuke">
  <article class="post-single">
    <header class="post-header">
      <h1 class="post-title">About</h1>
    </header>
    <div class="post-content">
      <p>Ohshima Yusuke</p>
      <ul>
        <li><a href="https://github.com/yukkeorg" target="_blank" rel="noopener noreferrer">GitHub: @yukkeorg</a></li>
        <li><a href="https://x.com/yukkeorg" target="_blank" rel="noopener noreferrer">X: @yukkeorg</a></li>
        <li><a href="https://zenn.dev/yukkeorg" target="_blank" rel="noopener noreferrer">Zenn: @yukkeorg</a></li>
      </ul>
    </div>
  </article>
</Layout>

<style>
  .post-single {
    max-width: 100%;
  }

  .post-header {
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--theme-border);
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
  }

  .post-content {
    line-height: 1.8;
  }

  .post-content p {
    margin: 0 0 16px;
  }

  .post-content ul {
    padding-left: 20px;
  }

  .post-content li {
    margin-bottom: 8px;
  }
</style>
