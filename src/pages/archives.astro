---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Archives" description="Archives of all posts">
  <article class="post-single">
    <header class="post-header">
      <h1 class="post-title">Archives</h1>
    </header>
    <div class="post-content">
      <p>No posts yet.</p>
    </div>
  </article>
</Layout>

<style>
  .post-single {
    max-width: 100%;
  }

  .post-header {
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--theme-border);
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
  }

  .post-content {
    line-height: 1.8;
    color: var(--theme-text-secondary);
  }
</style>
