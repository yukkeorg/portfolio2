---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Yukke.org" description="Ohshima Yusuke's personal website">
  <div class="profile">
    <img
      src="/my_avatar.png"
      alt="Ohshima Yusuke"
      class="avatar"
      width="120"
      height="120"
    />
    <h1 class="name">Ohshima Yusuke</h1>
    <div class="social-links">
      <a
        href="https://github.com/yukkeorg"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        title="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>
      <a
        href="https://x.com/yukkeorg"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="X (Twitter)"
        title="X (Twitter)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a
        href="https://zenn.dev/yukkeorg"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Zenn"
        title="Zenn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 88 88" fill="currentColor">
          <path d="M0 0h88v88H0z" fill="none"/>
          <path d="M9.3 74.1L38 24.4h12L21.2 74.1H9.3zM37.6 74.1L66.3 24.4h12L49.5 74.1H37.6z"/>
          <path d="M55.9 57.2l7.7-13.3 14.4 30.2H65.9l-10-16.9z"/>
        </svg>
      </a>
    </div>
  </div>
</Layout>

<style>
  .profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - var(--header-height) - var(--gap) * 4 - 90px);
    padding: 60px 0;
    gap: 16px;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--theme-border);
  }

  .name {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    color: var(--theme-text);
  }

  .social-links {
    display: flex;
    gap: 20px;
    margin-top: 8px;
  }

  .social-links a {
    color: var(--theme-text-secondary);
    display: flex;
    align-items: center;
    transition: color 0.2s, transform 0.2s;
  }

  .social-links a:hover {
    color: var(--theme-text);
    transform: translateY(-2px);
    text-decoration: none;
  }
</style>
