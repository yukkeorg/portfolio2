---
import SocialLinks from "./SocialLinks.astro";

interface Props {
  name?: string;
  realname?: string;
  avatarSrc?: string;
}

const { name, realname, avatarSrc } = Astro.props;
---

<div class="profile">
  <img src={avatarSrc} alt={name} class="avatar" width="120" height="120" />
  <h1 class="name">{name}</h1>
  <h2 class="realname">{realname}</h2>
  <SocialLinks />
</div>

<style>
  .profile {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(
      100vh - var(--header-height) - var(--gap) * 4 - var(--footer-height)
    );
    padding: 60px 0;
    gap: 16px;
  }

  .avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--theme-border);
  }

  .name {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    color: var(--theme-text);
  }

  .realname {
    font-size: 1rem;
    font-weight: 400;
    margin: 0;
    color: var(--theme-text-secondary);
  }
</style>
