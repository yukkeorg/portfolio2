---
import ThemeToggle from "./ThemeToggle.astro";

type LinkProperty = {
  label: string;
  href: string;
};

const nav: LinkProperty[] = [
  // { label: "About", href: "/about/" },
  // { label: "Archives", href: "/archives/" },
];
---

<header class="header">
  <nav class="nav">
    <a
      href="/"
      class="logo"
      accesskey="h"
      title="Yukke.org Portfolio (Alt + H)"
    >
    </a>
    <ul class="menu">
      {
        nav.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))
      }
      <li>
        <ThemeToggle />
      </li>
    </ul>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--theme-header-bg);
    height: var(--header-height);
    display: flex;
    align-items: center;
  }

  .nav {
    max-width: var(--nav-width);
    margin: 0 auto;
    padding: 0 var(--gap);
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    font-size: 18px;
    font-weight: 700;
    color: var(--theme-text);
    text-decoration: none;
    white-space: nowrap;
  }

  .menu {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .menu a {
    color: var(--theme-text);
    font-size: 14px;
    font-weight: 500;
    padding: 6px 10px;
    border-radius: var(--radius);
    text-decoration: none;
    transition: background 0.15s;
  }

  .menu a:hover {
    background: var(--theme-border);
    text-decoration: none;
  }
</style>
